# ==============================================================================
# AAOS — Environment Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# .env is gitignored and never committed.
# ==============================================================================

# ── Workspace ─────────────────────────────────────────────────────────────────
# Where skills, scripts, BOOT.md, memory, and sessions are stored.
# Default: ./workspace  (inside the repo, versioned with code)
# Override to use a personal or shared workspace outside the repo.
#
# Windows examples:
#   AAOS_WORKSPACE=C:\Users\YourName\Code\AAOS\workspace   ← default (in repo)
#   AAOS_WORKSPACE=C:\Users\YourName\.aaos                 ← personal
#
# Linux / macOS examples:
#   AAOS_WORKSPACE=./workspace                              ← default (in repo)
#   AAOS_WORKSPACE=/home/yourname/.aaos                    ← personal
#
AAOS_WORKSPACE=./workspace

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: anthropic | google | anthropic-vertex | ollama
AAOS_LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Google Vertex AI (Gemini) ─────────────────────────────────────────────────
# AAOS_LLM_PROVIDER=google
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.0-flash
# GOOGLE_APPLICATION_CREDENTIALS=C:\Users\YourName\keys\service-account.json

# ── Claude on Vertex AI ───────────────────────────────────────────────────────
# AAOS_LLM_PROVIDER=anthropic-vertex
# VERTEX_PROJECT_ID=your-gcp-project-id
# ANTHROPIC_VERTEX_MODEL=claude-sonnet-4-5
# ANTHROPIC_VERTEX_REGION=us-east5
# GOOGLE_APPLICATION_CREDENTIALS=C:\Users\YourName\keys\service-account.json

# ── Server ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Scheduler ─────────────────────────────────────────────────────────────────
TZ=Asia/Hong_Kong

# ── Snapshots (webcam captures) ───────────────────────────────────────────────
# AAOS_SNAPSHOTS_DIR=C:\Temp\aaos_snapshots

# ── LINE Messaging API (optional) ─────────────────────────────────────────────
# LINE_CHANNEL_SECRET=your-line-channel-secret
# LINE_CHANNEL_ACCESS_TOKEN=your-line-access-token
